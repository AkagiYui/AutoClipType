    "settings.inputMode.physicalKeyboard.description" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sends real key codes for ASCII text. Best for browsers, noVNC, and remote consoles."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "按真实键码输入 ASCII 文本，适合浏览器、noVNC 和远程控制台。"
          }
        }
      }
    },
